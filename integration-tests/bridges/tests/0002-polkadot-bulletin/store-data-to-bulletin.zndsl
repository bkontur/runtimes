Description: Store data on Bulletin with authorized account.
Network: {{ENV_PATH}}/polkadot_bulletin_local_network.toml
Creds: config

# Check authorization for 2 transactions.
alice: js-script ./check-authorization.js with '{ "account": "5GrwvaEF5zXb26Fz9rcQpDWS57CtERHpNehXCPcNoHGKutQY", "isAuthorized": true, "transactions": 2 }' within 30 seconds

# Store data with authorized account seed. 0x48656c6c6f20576f726c64 ("Hello World" in hex)
alice: js-script ./store-data.js with '{ "authorizedAccountSeed": "//Alice", "data": "0x48656c6c6f20576f726c64" }' within 30 seconds

# Check authorization only for 1 transactions.
alice: js-script ./check-authorization.js with '{ "account": "5GrwvaEF5zXb26Fz9rcQpDWS57CtERHpNehXCPcNoHGKutQY", "isAuthorized": true, "transactions": 1 }' within 30 seconds
